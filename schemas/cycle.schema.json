{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nbardy/oompa_loompas/schemas/cycle.schema.json",
  "title": "OompaCycle",
  "description": "Worker cycle event. One complete work unit. File: runs/{swarm-id}/cycles/{worker-id}-c{N}.json",
  "type": "object",
  "required": ["worker-id", "cycle", "outcome", "timestamp", "duration-ms", "recycled-tasks", "review-rounds"],
  "properties": {
    "worker-id": { "type": "string" },
    "cycle": { "type": "integer", "minimum": 1 },
    "outcome": {
      "type": "string",
      "enum": ["merged", "rejected", "error", "done", "executor-done", "no-changes", "working", "claimed", "sync-failed", "merge-failed", "interrupted", "stuck"]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "duration-ms": { "type": "integer", "minimum": 0 },
    "claimed-task-ids": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Task IDs claimed via CLAIM signal during this cycle"
    },
    "recycled-tasks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error-snippet": { "type": ["string", "null"] },
    "review-rounds": { "type": "integer", "minimum": 0 },
    "timing-ms": {
      "type": "object",
      "properties": {
        "implementation-rounds-ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "reviewer-response-ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "review-fixes-ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "optional-review-ms": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "harness-ms": {
          "type": "integer",
          "minimum": 0
        },
        "other-ms": {
          "type": "integer",
          "minimum": 0
        },
        "llm-calls": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "section", "duration-ms"],
            "properties": {
              "name": { "type": "string" },
              "section": { "type": "string" },
              "duration-ms": { "type": "integer", "minimum": 0 },
              "percent": { "type": "number", "minimum": 0, "maximum": 100 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
